{
  "name": "nina.fm-website",
  "version": "2.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:api": "cd ../nina.fm-api && pnpm start:dev",
    "dev:stack": "concurrently -k -n API,Front -c bgWhite,bgBlack \"pnpm dev:api\" \"pnpm dev\"",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write --list-different \"./*.{js,jsx,ts,tsx,vue,html,css,scss,json,md}\" \"app/**/*.{js,jsx,ts,tsx,vue,html,css,scss,json,md}\" \"server/**/*.{js,ts}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "version:check": "changeset status"
  },
  "dependencies": {
    "@nuxtjs/device": "4.0.0",
    "@tanstack/vue-table": "^8.21.2",
    "@vueuse/nuxt": "14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html-entities": "^2.5.2",
    "lucide-vue-next": "^0.577.0",
    "mime": "^4.0.6",
    "nuxt": "^4.3.1",
    "reka-ui": "^2.9.0",
    "shadcn-nuxt": "2.4.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "uniqid": "^5.4.0",
    "vaul-vue": "^0.4.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@lewebsimple/nuxt3-svg": "^0.2.2",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/kit": "^4.3.1",
    "@nuxt/ui-templates": "^1.3.4",
    "@nuxtjs/sitemap": "^7.6.0",
    "@nuxtjs/tailwindcss": "^6.13.2",
    "@pinia/nuxt": "^0.11.3",
    "@types/node": "^25.3.5",
    "@types/uniqid": "^5.3.4",
    "@vite-pwa/nuxt": "^1.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.5.5",
    "npm-run-all": "^4.1.5",
    "pinia": "^3.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.8.2",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "packageManager": "pnpm@10.13.1"
}
