# Nina.fm Website — Environment Variables
# Copier ce fichier en .env et ajuster les valeurs

# ─── Développement local ────────────────────────────────────────────────────

NODE_ENV=development

# URL du flux audio Nina.fm
NUXT_PUBLIC_AUDIO_STREAM_URL=https://flux.nina.fm/nina.mp3

# URL de l'API Nina (locale en dev)
NUXT_PUBLIC_API_URL=http://localhost:4000

# Endpoint SSE pour les métadonnées de la piste en cours
NUXT_PUBLIC_API_STREAM_ENDPOINT=/stream

# Port du serveur de dev (optionnel, défaut : 3000)
FRONT_OUTPUT_PORT=3000

# ─── Production ─────────────────────────────────────────────────────────────
# Ces valeurs sont injectées via les GitHub Actions Variables (vars.*)
# et le fichier .env sur le serveur — ne pas les committer.
#
# NODE_ENV=production
# NUXT_PUBLIC_AUDIO_STREAM_URL=https://flux.nina.fm/nina.mp3
# NUXT_PUBLIC_API_URL=https://api.nina.fm
# NUXT_PUBLIC_API_STREAM_ENDPOINT=/stream
